# ─── Pisom OS - Variáveis de Ambiente (Produção) ───────────────────
# Copie este arquivo para .env e preencha os valores

# Senha do banco de dados PostgreSQL
DB_PASSWORD=SuaSenhaSeguraAqui123!

# Chave secreta para tokens JWT (mínimo 32 caracteres)
JWT_SECRET=troque-por-uma-chave-segura-com-pelo-menos-64-caracteres-aqui!!

# Domínio (sem alterar se usar sistema.pisommidias.com.br)
DOMAIN=sistema.pisommidias.com.br

# Email para certificado SSL (Let's Encrypt)
CERTBOT_EMAIL=seu-email@pisommidias.com.br
