{
  "version": 2,
  "buildCommand": "npx prisma db push --accept-data-loss && npx prisma generate && npm run build",
  "outputDirectory": "dist",
  "functions": {
    "api/index.ts": {
      "maxDuration": 30
    }
  },
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/api"
    }
  ]
}
