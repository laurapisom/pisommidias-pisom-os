generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================
// IDENTIDADE, CONTAS E PERMISSÕES
// ============================================================

model Organization {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  logo      String?
  cnpj      String?
  email     String?
  phone     String?
  address   String?
  city      String?
  state     String?
  zipCode   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  members             OrganizationMember[]
  teams               Team[]
  leads               Lead[]
  contacts            Contact[]
  companies           Company[]
  deals               Deal[]
  pipelines           Pipeline[]
  tasks               Task[]
  auditLogs           AuditLog[]
  tags                Tag[]
  onboardings         Onboarding[]
  onboardingTemplates OnboardingTemplate[]
  contracts           Contract[]
  invoices            Invoice[]
  expenses            Expense[]
  costCenters         CostCenter[]
  expenseCategories   ExpenseCategory[]
  contentPosts        ContentPost[]
  contentIdeas        ContentIdea[]
  clientProfiles      ClientContentProfile[]
  // Financial Core
  bankAccounts        BankAccount[]
  bankTransfers       BankTransfer[]
  financialCategories FinancialCategory[]
  financialEntries    FinancialEntry[]
  financialRecurrences FinancialRecurrence[]
  cashFlowSnapshots   CashFlowSnapshot[]
  reconciliationImports BankReconciliationImport[]
  asaasAccounts       AsaasAccount[]
  asaasCustomers      AsaasCustomer[]
  asaasPayments       AsaasPayment[]
  asaasSubscriptions  AsaasSubscription[]
  asaasWebhooks       AsaasWebhook[]
  billingDocuments    BillingDocument[]
  financialNotifications FinancialNotification[]
  syncLogs            SyncLog[]
  systemSettings      SystemSetting[]
  financialPermissions FinancialPermission[]

  @@map("organizations")
}

model User {
  id           String    @id @default(cuid())
  email        String    @unique
  passwordHash String
  firstName    String
  lastName     String
  avatar       String?
  phone        String?
  isActive     Boolean   @default(true)
  lastLoginAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  memberships     OrganizationMember[]
  teamMembers     TeamMember[]
  assignedTasks   Task[]            @relation("TaskAssignee")
  createdTasks    Task[]            @relation("TaskCreator")
  createdDeals    Deal[]            @relation("DealCreator")
  ownedDeals      Deal[]            @relation("DealOwner")
  activities      Activity[]
  auditLogs       AuditLog[]
  comments        Comment[]
  onboardingsResponsible Onboarding[] @relation("OnboardingResponsible")
  onboardingItemsCompleted OnboardingItem[] @relation("OnboardingItemCompletedBy")
  expensesCreated  Expense[] @relation("ExpenseCreator")
  expensesApproved Expense[] @relation("ExpenseApprover")
  contentPostsCreated  ContentPost[] @relation("ContentPostCreator")
  contentPostsAssigned ContentPost[] @relation("ContentPostAssignee")
  contentIdeasCreated  ContentIdea[] @relation("ContentIdeaCreator")
  contentVersions      ContentVersion[]
  // Financial Core
  financialEntriesCreated   FinancialEntry[] @relation("EntryCreator")
  financialEntriesApproved  FinancialEntry[] @relation("EntryApprover")
  financialPermissions      FinancialPermission[]

  @@map("users")
}

model OrganizationMember {
  id             String   @id @default(cuid())
  organizationId String
  userId         String
  role           OrgRole  @default(MEMBER)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([organizationId, userId])
  @@map("organization_members")
}

enum OrgRole {
  OWNER
  ADMIN
  MANAGER
  MEMBER
  VIEWER
}

model Team {
  id             String   @id @default(cuid())
  organizationId String
  name           String
  description    String?
  color          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  members      TeamMember[]

  @@map("teams")
}

model TeamMember {
  id        String   @id @default(cuid())
  teamId    String
  userId    String
  role      String   @default("member")
  createdAt DateTime @default(now())

  team Team @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([teamId, userId])
  @@map("team_members")
}

model AuditLog {
  id             String   @id @default(cuid())
  organizationId String
  userId         String?
  action         String
  entity         String
  entityId       String?
  oldData        Json?
  newData        Json?
  ipAddress      String?
  userAgent      String?
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User?        @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([organizationId, entity, entityId])
  @@index([organizationId, createdAt])
  @@map("audit_logs")
}

// ============================================================
// PERMISSÕES FINANCEIRAS GRANULARES
// ============================================================

model FinancialPermission {
  id             String   @id @default(cuid())
  organizationId String
  userId         String
  role           FinancialRole @default(VIEWER)
  permissions    Json     // JSON with granular permissions
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([organizationId, userId])
  @@map("financial_permissions")
}

enum FinancialRole {
  ADMIN_MASTER
  FINANCIAL
  MANAGER
  FINANCIAL_SUPPORT
  EXTERNAL_CLIENT
  AUDITOR
  VIEWER
}

// ============================================================
// CRM + PIPELINE DE VENDAS
// ============================================================

model Contact {
  id             String   @id @default(cuid())
  organizationId String
  firstName      String
  lastName       String?
  email          String?
  phone          String?
  whatsapp       String?
  position       String?
  companyId      String?
  avatar         String?
  customFields   Json?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  company      Company?     @relation(fields: [companyId], references: [id], onDelete: SetNull)
  leads        Lead[]
  deals        DealContact[]
  activities   Activity[]

  @@index([organizationId, email])
  @@map("contacts")
}

model Company {
  id             String   @id @default(cuid())
  organizationId String
  name           String
  domain         String?
  cnpj           String?
  phone          String?
  address        String?
  city           String?
  state          String?
  industry       String?
  size           String?
  logo           String?
  customFields   Json?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  contacts     Contact[]
  leads        Lead[]
  deals        Deal[]

  @@index([organizationId])
  @@map("companies")
}

model Lead {
  id             String     @id @default(cuid())
  organizationId String
  contactId      String?
  companyId      String?
  source         String?
  status         LeadStatus @default(NEW)
  score          Int        @default(0)
  customFields   Json?
  convertedAt    DateTime?
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  contact      Contact?     @relation(fields: [contactId], references: [id], onDelete: SetNull)
  company      Company?     @relation(fields: [companyId], references: [id], onDelete: SetNull)
  deals        Deal[]
  activities   Activity[]
  tags         TagAssignment[]

  @@index([organizationId, status])
  @@index([organizationId, createdAt])
  @@map("leads")
}

enum LeadStatus {
  NEW
  CONTACTED
  QUALIFIED
  UNQUALIFIED
  CONVERTED
  LOST
}

model Pipeline {
  id             String   @id @default(cuid())
  organizationId String
  name           String
  description    String?
  isDefault      Boolean  @default(false)
  position       Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  stages       PipelineStage[]
  deals        Deal[]

  @@map("pipelines")
}

model PipelineStage {
  id         String   @id @default(cuid())
  pipelineId String
  name       String
  color      String?
  position   Int      @default(0)
  probability Int     @default(0)
  slaHours   Int?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  pipeline Pipeline @relation(fields: [pipelineId], references: [id], onDelete: Cascade)
  deals    Deal[]

  @@map("pipeline_stages")
}

model Deal {
  id             String     @id @default(cuid())
  organizationId String
  pipelineId     String
  stageId        String
  leadId         String?
  companyId      String?
  ownerId        String
  createdById    String
  title          String
  value          Decimal?   @db.Decimal(12, 2)
  currency       String     @default("BRL")
  status         DealStatus @default(OPEN)
  expectedCloseDate DateTime?
  closedAt       DateTime?
  lostReason     String?
  wonReason      String?
  position       Int        @default(0)
  customFields   Json?
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  organization Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  pipeline     Pipeline      @relation(fields: [pipelineId], references: [id])
  stage        PipelineStage @relation(fields: [stageId], references: [id])
  lead         Lead?         @relation(fields: [leadId], references: [id], onDelete: SetNull)
  company      Company?      @relation(fields: [companyId], references: [id], onDelete: SetNull)
  owner        User          @relation("DealOwner", fields: [ownerId], references: [id])
  createdBy    User          @relation("DealCreator", fields: [createdById], references: [id])
  contacts     DealContact[]
  activities   Activity[]
  tasks        Task[]
  tags         TagAssignment[]
  comments     Comment[]

  @@index([organizationId, pipelineId, stageId])
  @@index([organizationId, status])
  @@map("deals")
}

model DealContact {
  id        String @id @default(cuid())
  dealId    String
  contactId String
  role      String @default("primary")

  deal    Deal    @relation(fields: [dealId], references: [id], onDelete: Cascade)
  contact Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@unique([dealId, contactId])
  @@map("deal_contacts")
}

enum DealStatus {
  OPEN
  WON
  LOST
  ARCHIVED
}

// ============================================================
// ATIVIDADES E TIMELINE
// ============================================================

model Activity {
  id             String       @id @default(cuid())
  organizationId String
  userId         String
  type           ActivityType
  title          String
  description    String?
  metadata       Json?
  leadId         String?
  dealId         String?
  contactId      String?
  scheduledAt    DateTime?
  completedAt    DateTime?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  user    User     @relation(fields: [userId], references: [id])
  lead    Lead?    @relation(fields: [leadId], references: [id], onDelete: SetNull)
  deal    Deal?    @relation(fields: [dealId], references: [id], onDelete: SetNull)
  contact Contact? @relation(fields: [contactId], references: [id], onDelete: SetNull)

  @@index([dealId, createdAt])
  @@index([leadId, createdAt])
  @@index([contactId, createdAt])
  @@map("activities")
}

enum ActivityType {
  NOTE
  CALL
  EMAIL
  MEETING
  TASK
  WHATSAPP
  PROPOSAL
  CONTRACT
  STAGE_CHANGE
  STATUS_CHANGE
  SYSTEM
}

// ============================================================
// TAREFAS E FOLLOW-UPS
// ============================================================

model Task {
  id             String     @id @default(cuid())
  organizationId String
  assigneeId     String?
  createdById    String
  dealId         String?
  title          String
  description    String?
  priority       Priority   @default(MEDIUM)
  status         TaskStatus @default(TODO)
  dueDate        DateTime?
  completedAt    DateTime?
  slaDeadline    DateTime?
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  assignee     User?        @relation("TaskAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)
  createdBy    User         @relation("TaskCreator", fields: [createdById], references: [id])
  deal         Deal?        @relation(fields: [dealId], references: [id], onDelete: SetNull)
  comments     Comment[]
  tags         TagAssignment[]

  @@index([organizationId, status])
  @@index([assigneeId, status])
  @@index([dueDate])
  @@map("tasks")
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  WAITING
  DONE
  CANCELLED
}

// ============================================================
// TAGS E COMENTÁRIOS
// ============================================================

model Tag {
  id             String   @id @default(cuid())
  organizationId String
  name           String
  color          String?
  createdAt      DateTime @default(now())

  organization Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  assignments  TagAssignment[]

  @@unique([organizationId, name])
  @@map("tags")
}

model TagAssignment {
  id         String @id @default(cuid())
  tagId      String
  entityType String
  entityId   String

  tag Tag @relation(fields: [tagId], references: [id], onDelete: Cascade)

  leadId String?
  lead   Lead?   @relation(fields: [leadId], references: [id], onDelete: Cascade)
  dealId String?
  deal   Deal?   @relation(fields: [dealId], references: [id], onDelete: Cascade)
  taskId String?
  task   Task?   @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@unique([tagId, entityType, entityId])
  @@index([entityType, entityId])
  @@map("tag_assignments")
}

model Comment {
  id        String   @id @default(cuid())
  userId    String
  content   String
  entityType String
  entityId  String
  dealId    String?
  taskId    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User  @relation(fields: [userId], references: [id])
  deal Deal? @relation(fields: [dealId], references: [id], onDelete: Cascade)
  task Task? @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([entityType, entityId])
  @@map("comments")
}

// ============================================================
// ONBOARDING E DIAGNÓSTICO
// ============================================================

model OnboardingTemplate {
  id             String   @id @default(cuid())
  organizationId String
  name           String
  description    String?
  serviceType    ServiceType
  isActive       Boolean  @default(true)
  position       Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization              @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  sections     OnboardingTemplateSection[]
  onboardings  Onboarding[]

  @@index([organizationId, serviceType])
  @@map("onboarding_templates")
}

model OnboardingTemplateSection {
  id         String   @id @default(cuid())
  templateId String
  name       String
  description String?
  position   Int      @default(0)
  createdAt  DateTime @default(now())

  template OnboardingTemplate            @relation(fields: [templateId], references: [id], onDelete: Cascade)
  items    OnboardingTemplateItem[]

  @@map("onboarding_template_sections")
}

model OnboardingTemplateItem {
  id          String                @id @default(cuid())
  sectionId   String
  title       String
  description String?
  itemType    OnboardingItemType    @default(CHECKBOX)
  isRequired  Boolean               @default(true)
  position    Int                   @default(0)
  metadata    Json?
  createdAt   DateTime              @default(now())

  section OnboardingTemplateSection @relation(fields: [sectionId], references: [id], onDelete: Cascade)

  @@map("onboarding_template_items")
}

enum ServiceType {
  TRAFEGO_PAGO
  SOCIAL_MEDIA
  WEBSITE
  CRM_AUTOMACAO
  BRANDING
  SEO
  EMAIL_MARKETING
  CONSULTORIA
  CUSTOM
}

enum OnboardingItemType {
  CHECKBOX
  TEXT_INPUT
  FILE_UPLOAD
  URL_INPUT
  CREDENTIAL
  SELECT
  DATE
  SIGNATURE
}

model Onboarding {
  id             String           @id @default(cuid())
  organizationId String
  templateId     String?
  dealId         String?
  companyId      String?
  responsibleId  String?
  title          String
  serviceType    ServiceType
  status         OnboardingStatus @default(PENDING)
  notes          String?
  startedAt      DateTime?
  completedAt    DateTime?
  dueDate        DateTime?
  acceptedTermsAt DateTime?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  organization Organization         @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  template     OnboardingTemplate?  @relation(fields: [templateId], references: [id], onDelete: SetNull)
  responsible  User?                @relation("OnboardingResponsible", fields: [responsibleId], references: [id], onDelete: SetNull)
  sections     OnboardingSection[]

  @@index([organizationId, status])
  @@index([organizationId, dealId])
  @@map("onboardings")
}

enum OnboardingStatus {
  PENDING
  IN_PROGRESS
  WAITING_CLIENT
  REVIEW
  COMPLETED
  CANCELLED
}

model OnboardingSection {
  id            String   @id @default(cuid())
  onboardingId  String
  name          String
  description   String?
  position      Int      @default(0)
  createdAt     DateTime @default(now())

  onboarding Onboarding       @relation(fields: [onboardingId], references: [id], onDelete: Cascade)
  items      OnboardingItem[]

  @@map("onboarding_sections")
}

model OnboardingItem {
  id            String              @id @default(cuid())
  sectionId     String
  title         String
  description   String?
  itemType      OnboardingItemType  @default(CHECKBOX)
  isRequired    Boolean             @default(true)
  position      Int                 @default(0)
  isCompleted   Boolean             @default(false)
  completedAt   DateTime?
  completedById String?
  value         String?
  fileUrl       String?
  notes         String?
  metadata      Json?
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt

  section     OnboardingSection @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  completedBy User?             @relation("OnboardingItemCompletedBy", fields: [completedById], references: [id], onDelete: SetNull)

  @@map("onboarding_items")
}

// ============================================================
// FINANCEIRO: CONTRATOS E RECORRÊNCIA
// ============================================================

model Contract {
  id             String         @id @default(cuid())
  organizationId String
  companyId      String?
  dealId         String?
  title          String
  description    String?
  status         ContractStatus @default(ACTIVE)
  billingCycle   BillingCycle   @default(MONTHLY)
  value          Decimal        @db.Decimal(12, 2)
  currency       String         @default("BRL")
  startDate      DateTime
  endDate        DateTime?
  nextBillingDate DateTime?
  dayOfMonth     Int            @default(10)
  autoRenew      Boolean        @default(true)
  services       String[]
  asaasCustomerId  String?
  asaasSubscriptionId String?
  notes          String?
  cancelledAt    DateTime?
  cancelReason   String?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  invoices     Invoice[]

  @@index([organizationId, status])
  @@index([organizationId, companyId])
  @@index([nextBillingDate])
  @@map("contracts")
}

enum ContractStatus {
  DRAFT
  ACTIVE
  PAUSED
  CANCELLED
  EXPIRED
}

enum BillingCycle {
  WEEKLY
  BIWEEKLY
  MONTHLY
  QUARTERLY
  SEMIANNUAL
  ANNUAL
  CUSTOM
}

model Invoice {
  id             String        @id @default(cuid())
  organizationId String
  contractId     String?
  companyId      String?
  number         String?
  status         InvoiceStatus @default(PENDING)
  type           InvoiceType   @default(RECURRING)
  value          Decimal       @db.Decimal(12, 2)
  discount       Decimal?      @db.Decimal(12, 2)
  tax            Decimal?      @db.Decimal(12, 2)
  totalValue     Decimal       @db.Decimal(12, 2)
  currency       String        @default("BRL")
  description    String?
  dueDate        DateTime
  paidAt         DateTime?
  paidValue      Decimal?      @db.Decimal(12, 2)
  paymentMethod  String?
  referenceMonth String?
  asaasPaymentId String?
  asaasBillingType String?
  asaasInvoiceUrl  String?
  asaasBankSlipUrl String?
  asaasPixCode     String?
  notes          String?
  reminders      Json?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  contract     Contract?    @relation(fields: [contractId], references: [id], onDelete: SetNull)

  @@index([organizationId, status])
  @@index([organizationId, dueDate])
  @@index([organizationId, contractId])
  @@index([asaasPaymentId])
  @@map("invoices")
}

enum InvoiceStatus {
  DRAFT
  PENDING
  SENT
  OVERDUE
  PAID
  PARTIALLY_PAID
  CANCELLED
  REFUNDED
}

enum InvoiceType {
  RECURRING
  ONE_TIME
  ADDITIONAL
  CREDIT
}

// ============================================================
// FINANCEIRO: DESPESAS, CENTROS DE CUSTO E FLUXO DE CAIXA (LEGADO)
// ============================================================

model ExpenseCategory {
  id             String   @id @default(cuid())
  organizationId String
  name           String
  color          String?
  parentId       String?
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())

  organization Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  parent       ExpenseCategory?  @relation("ExpenseCategoryTree", fields: [parentId], references: [id], onDelete: SetNull)
  children     ExpenseCategory[] @relation("ExpenseCategoryTree")
  expenses     Expense[]

  @@unique([organizationId, name])
  @@map("expense_categories")
}

model CostCenter {
  id             String   @id @default(cuid())
  organizationId String
  name           String
  code           String?
  description    String?
  parentId       String?
  type           CostCenterType @default(GENERAL)
  referenceId    String?
  isActive       Boolean  @default(true)
  budget         Decimal? @db.Decimal(12, 2)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization     Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  expenses         Expense[]
  financialEntries FinancialEntry[]

  @@unique([organizationId, name])
  @@map("cost_centers")
}

enum CostCenterType {
  CLIENT
  PROJECT
  SQUAD
  DEPARTMENT
  GENERAL
}

model Expense {
  id             String        @id @default(cuid())
  organizationId String
  categoryId     String?
  costCenterId   String?
  createdById    String
  approvedById   String?
  title          String
  description    String?
  value          Decimal       @db.Decimal(12, 2)
  currency       String        @default("BRL")
  status         ExpenseStatus @default(PENDING)
  type           ExpenseType   @default(FIXED)
  dueDate        DateTime
  paidAt         DateTime?
  recurrence     BillingCycle?
  supplier       String?
  invoiceNumber  String?
  attachmentUrl  String?
  notes          String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  organization Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  category     ExpenseCategory?  @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  costCenter   CostCenter?       @relation(fields: [costCenterId], references: [id], onDelete: SetNull)
  createdBy    User              @relation("ExpenseCreator", fields: [createdById], references: [id])
  approvedBy   User?             @relation("ExpenseApprover", fields: [approvedById], references: [id], onDelete: SetNull)

  @@index([organizationId, status])
  @@index([organizationId, dueDate])
  @@index([organizationId, categoryId])
  @@index([organizationId, costCenterId])
  @@map("expenses")
}

enum ExpenseStatus {
  PENDING
  APPROVED
  PAID
  REJECTED
  CANCELLED
}

enum ExpenseType {
  FIXED
  VARIABLE
  ONE_TIME
  INVESTMENT
}

// ============================================================
// FINANCEIRO CORE: CONTAS BANCÁRIAS
// ============================================================

model BankAccount {
  id             String          @id @default(cuid())
  organizationId String
  name           String
  type           BankAccountType @default(CHECKING)
  bankName       String?
  bankCode       String?
  agency         String?
  accountNumber  String?
  pixKey         String?
  pixKeyType     String?
  initialBalance Decimal         @db.Decimal(14, 2) @default(0)
  currentBalance Decimal         @db.Decimal(14, 2) @default(0)
  reconciledBalance Decimal      @db.Decimal(14, 2) @default(0)
  projectedBalance  Decimal      @db.Decimal(14, 2) @default(0)
  isPrimary      Boolean         @default(false)
  isActive       Boolean         @default(true)
  color          String?
  notes          String?
  closedPeriods  Json?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  organization       Organization              @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  financialEntries   FinancialEntry[]
  transfersFrom      BankTransfer[]            @relation("TransferFrom")
  transfersTo        BankTransfer[]            @relation("TransferTo")
  reconciliationImports BankReconciliationImport[]

  @@index([organizationId, isActive])
  @@map("bank_accounts")
}

enum BankAccountType {
  CHECKING
  SAVINGS
  INVESTMENT
  CASH
  DIGITAL
  OTHER
}

model BankTransfer {
  id                String   @id @default(cuid())
  organizationId    String
  fromAccountId     String
  toAccountId       String
  amount            Decimal  @db.Decimal(14, 2)
  description       String?
  transferDate      DateTime
  createdAt         DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  fromAccount  BankAccount  @relation("TransferFrom", fields: [fromAccountId], references: [id])
  toAccount    BankAccount  @relation("TransferTo", fields: [toAccountId], references: [id])

  @@index([organizationId, transferDate])
  @@map("bank_transfers")
}

// ============================================================
// FINANCEIRO CORE: CATEGORIAS FINANCEIRAS
// ============================================================

model FinancialCategory {
  id             String            @id @default(cuid())
  organizationId String
  name           String
  type           FinancialCatType
  color          String?
  icon           String?
  parentId       String?
  isActive       Boolean           @default(true)
  isSystem       Boolean           @default(false)
  position       Int               @default(0)
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  organization Organization          @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  parent       FinancialCategory?    @relation("FinancialCategoryTree", fields: [parentId], references: [id], onDelete: SetNull)
  children     FinancialCategory[]   @relation("FinancialCategoryTree")
  entries      FinancialEntry[]

  @@unique([organizationId, name, type])
  @@map("financial_categories")
}

enum FinancialCatType {
  REVENUE
  EXPENSE
}

// ============================================================
// FINANCEIRO CORE: LANÇAMENTOS FINANCEIROS
// ============================================================

model FinancialEntry {
  id                String              @id @default(cuid())
  organizationId    String
  type              EntryType
  status            EntryStatus         @default(PENDING)
  description       String
  notes             String?             @db.Text
  value             Decimal             @db.Decimal(14, 2)
  currency          String              @default("BRL")
  competenceDate    DateTime
  dueDate           DateTime
  paymentDate       DateTime?
  paidValue         Decimal?            @db.Decimal(14, 2)
  documentNumber    String?
  categoryId        String?
  costCenterId      String?
  bankAccountId     String?
  paymentMethod     PaymentMethod?
  // Relationships
  contactName       String?
  contactDocument   String?
  contactType       ContactFinType?
  // Recurrence
  recurrenceId      String?
  installmentNumber Int?
  totalInstallments Int?
  parentEntryId     String?
  // Tags
  tags              String[]
  // Audit
  createdById       String
  approvedById      String?
  approvedAt        DateTime?
  // Soft delete
  deletedAt         DateTime?
  deletedById       String?
  deleteReason      String?
  // Asaas link
  asaasPaymentId    String?
  // Version
  version           Int                 @default(1)
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt

  organization   Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  category       FinancialCategory?  @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  costCenter     CostCenter?         @relation(fields: [costCenterId], references: [id], onDelete: SetNull)
  bankAccount    BankAccount?        @relation(fields: [bankAccountId], references: [id], onDelete: SetNull)
  createdBy      User                @relation("EntryCreator", fields: [createdById], references: [id])
  approvedBy     User?               @relation("EntryApprover", fields: [approvedById], references: [id], onDelete: SetNull)
  recurrence     FinancialRecurrence? @relation(fields: [recurrenceId], references: [id], onDelete: SetNull)
  parentEntry    FinancialEntry?     @relation("EntryInstallments", fields: [parentEntryId], references: [id], onDelete: SetNull)
  installments   FinancialEntry[]    @relation("EntryInstallments")
  attachments    FinancialAttachment[]
  timeline       FinancialEntryEvent[]
  reconciliationMatches BankReconciliationMatch[]

  @@index([organizationId, type, status])
  @@index([organizationId, dueDate])
  @@index([organizationId, competenceDate])
  @@index([organizationId, categoryId])
  @@index([organizationId, costCenterId])
  @@index([organizationId, bankAccountId])
  @@index([organizationId, contactName])
  @@index([asaasPaymentId])
  @@index([recurrenceId])
  @@index([parentEntryId])
  @@index([organizationId, deletedAt])
  @@map("financial_entries")
}

enum EntryType {
  RECEIVABLE
  PAYABLE
}

enum EntryStatus {
  PENDING
  CONFIRMED
  RECEIVED
  PAID
  OVERDUE
  CANCELLED
  REFUNDED
  PARTIALLY_PAID
}

enum PaymentMethod {
  BOLETO
  PIX
  CREDIT_CARD
  DEBIT_CARD
  BANK_TRANSFER
  CASH
  CHECK
  OTHER
}

enum ContactFinType {
  CLIENT
  SUPPLIER
  EMPLOYEE
  OTHER
}

model FinancialEntryEvent {
  id        String   @id @default(cuid())
  entryId   String
  event     String
  details   String?  @db.Text
  metadata  Json?
  userId    String?
  createdAt DateTime @default(now())

  entry FinancialEntry @relation(fields: [entryId], references: [id], onDelete: Cascade)

  @@index([entryId, createdAt])
  @@map("financial_entry_events")
}

model FinancialAttachment {
  id        String   @id @default(cuid())
  entryId   String
  fileName  String
  fileUrl   String
  fileType  String?
  fileSize  Int?
  createdAt DateTime @default(now())

  entry FinancialEntry @relation(fields: [entryId], references: [id], onDelete: Cascade)

  @@index([entryId])
  @@map("financial_attachments")
}

// ============================================================
// FINANCEIRO CORE: RECORRÊNCIAS
// ============================================================

model FinancialRecurrence {
  id                String          @id @default(cuid())
  organizationId    String
  type              EntryType
  description       String
  value             Decimal         @db.Decimal(14, 2)
  categoryId        String?
  costCenterId      String?
  bankAccountId     String?
  contactName       String?
  contactDocument   String?
  contactType       ContactFinType?
  frequency         BillingCycle    @default(MONTHLY)
  dayOfMonth        Int             @default(10)
  startDate         DateTime
  endDate           DateTime?
  nextDueDate       DateTime?
  status            RecurrenceStatus @default(ACTIVE)
  totalGenerated    Int             @default(0)
  asaasSubscriptionId String?
  notes             String?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  organization Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  entries      FinancialEntry[]

  @@index([organizationId, status])
  @@index([nextDueDate])
  @@map("financial_recurrences")
}

enum RecurrenceStatus {
  ACTIVE
  PAUSED
  CANCELLED
  COMPLETED
}

// ============================================================
// FINANCEIRO CORE: FLUXO DE CAIXA SNAPSHOTS
// ============================================================

model CashFlowSnapshot {
  id                String   @id @default(cuid())
  organizationId    String
  date              DateTime
  openingBalance    Decimal  @db.Decimal(14, 2)
  totalInflows      Decimal  @db.Decimal(14, 2)
  totalOutflows     Decimal  @db.Decimal(14, 2)
  closingBalance    Decimal  @db.Decimal(14, 2)
  projectedInflows  Decimal  @db.Decimal(14, 2)
  projectedOutflows Decimal  @db.Decimal(14, 2)
  projectedBalance  Decimal  @db.Decimal(14, 2)
  bankAccountId     String?
  costCenterId      String?
  metadata          Json?
  createdAt         DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, date, bankAccountId, costCenterId])
  @@index([organizationId, date])
  @@map("cash_flow_snapshots")
}

// ============================================================
// FINANCEIRO CORE: CONCILIAÇÃO BANCÁRIA
// ============================================================

model BankReconciliationImport {
  id             String                  @id @default(cuid())
  organizationId String
  bankAccountId  String
  fileName       String
  fileUrl        String?
  fileFormat     String                  @default("OFX")
  importDate     DateTime                @default(now())
  periodStart    DateTime?
  periodEnd      DateTime?
  totalItems     Int                     @default(0)
  matchedItems   Int                     @default(0)
  unmatchedItems Int                     @default(0)
  status         ReconciliationImportStatus @default(PENDING)
  processedAt    DateTime?
  closedAt       DateTime?
  closedById     String?
  notes          String?
  createdAt      DateTime                @default(now())
  updatedAt      DateTime                @updatedAt

  organization Organization              @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  bankAccount  BankAccount               @relation(fields: [bankAccountId], references: [id])
  items        BankReconciliationItem[]

  @@index([organizationId, bankAccountId])
  @@index([organizationId, status])
  @@map("bank_reconciliation_imports")
}

enum ReconciliationImportStatus {
  PENDING
  PROCESSING
  PROCESSED
  CLOSED
  ERROR
}

model BankReconciliationItem {
  id             String   @id @default(cuid())
  importId       String
  transactionDate DateTime
  description    String
  amount         Decimal  @db.Decimal(14, 2)
  type           String   // CREDIT or DEBIT
  externalId     String?
  fitId          String?
  checkNumber    String?
  memo           String?
  status         ReconciliationItemStatus @default(UNMATCHED)
  createdAt      DateTime @default(now())

  import  BankReconciliationImport  @relation(fields: [importId], references: [id], onDelete: Cascade)
  matches BankReconciliationMatch[]

  @@index([importId, status])
  @@map("bank_reconciliation_items")
}

enum ReconciliationItemStatus {
  MATCHED
  UNMATCHED
  IGNORED
  CREATED
}

model BankReconciliationMatch {
  id               String   @id @default(cuid())
  reconciliationItemId String
  entryId          String
  matchType        MatchType @default(MANUAL)
  confidence       Decimal?  @db.Decimal(5, 2)
  matchedAt        DateTime  @default(now())
  matchedById      String?
  notes            String?

  reconciliationItem BankReconciliationItem @relation(fields: [reconciliationItemId], references: [id], onDelete: Cascade)
  entry              FinancialEntry        @relation(fields: [entryId], references: [id], onDelete: Cascade)

  @@unique([reconciliationItemId, entryId])
  @@map("bank_reconciliation_matches")
}

enum MatchType {
  AUTO
  MANUAL
  SUGGESTED
  RULE
}

// ============================================================
// ASAAS: CONTAS E CONFIGURAÇÃO
// ============================================================

model AsaasAccount {
  id             String         @id @default(cuid())
  organizationId String
  name           String
  environment    AsaasEnvironment @default(SANDBOX)
  apiKey         String         // encrypted
  walletId       String?
  isActive       Boolean        @default(true)
  webhookToken   String?
  lastSyncAt     DateTime?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, environment])
  @@map("asaas_accounts")
}

enum AsaasEnvironment {
  SANDBOX
  PRODUCTION
}

// ============================================================
// ASAAS: CLIENTES FINANCEIROS
// ============================================================

model AsaasCustomer {
  id                String   @id @default(cuid())
  organizationId    String
  externalId        String   // Asaas customer ID (cus_xxx)
  name              String
  email             String?
  cpfCnpj           String
  phone             String?
  mobilePhone       String?
  address           String?
  addressNumber     String?
  complement        String?
  province          String?
  postalCode        String?
  cityName          String?
  state             String?
  country           String?  @default("BR")
  personType        String?  // FISICA or JURIDICA
  // Sync fields
  syncStatus        SyncStatus @default(SYNCED)
  lastSyncedAt      DateTime?
  lastRemoteHash    String?
  lastLocalHash     String?
  syncError         String?
  sourceOfTruth     String   @default("ASAAS")
  version           Int      @default(1)
  // Local reference
  localContactId    String?
  localCompanyId    String?
  remotePayload     Json?
  deletedAt         DateTime?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  organization Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  payments     AsaasPayment[]
  subscriptions AsaasSubscription[]

  @@unique([organizationId, externalId])
  @@unique([organizationId, cpfCnpj])
  @@index([organizationId, syncStatus])
  @@index([organizationId, email])
  @@map("asaas_customers")
}

enum SyncStatus {
  SYNCED
  PENDING
  ERROR
  DIVERGENT
  LOCAL_ONLY
  REMOTE_ONLY
}

// ============================================================
// ASAAS: COBRANÇAS / PAGAMENTOS
// ============================================================

model AsaasPayment {
  id                String   @id @default(cuid())
  organizationId    String
  externalId        String   // Asaas payment ID (pay_xxx)
  customerId        String   // FK to AsaasCustomer
  asaasCustomerId   String   // Asaas customer ID (cus_xxx)
  subscriptionId    String?  // FK to AsaasSubscription
  // Payment data
  billingType       String   // BOLETO, PIX, CREDIT_CARD, UNDEFINED
  value             Decimal  @db.Decimal(14, 2)
  netValue          Decimal? @db.Decimal(14, 2)
  discount          Decimal? @db.Decimal(14, 2)
  interest          Decimal? @db.Decimal(14, 2)
  fine              Decimal? @db.Decimal(14, 2)
  description       String?
  externalReference String?
  dueDate           DateTime
  paymentDate       DateTime?
  clientPaymentDate DateTime?
  originalDueDate   DateTime?
  // Status
  status            String   // PENDING, RECEIVED, CONFIRMED, OVERDUE, etc.
  // Links
  invoiceUrl        String?
  bankSlipUrl       String?
  pixQrCodeUrl      String?
  pixPayload        String?  @db.Text
  transactionReceiptUrl String?
  // Refund
  refundedValue     Decimal? @db.Decimal(14, 2)
  refundedAt        DateTime?
  // Sync fields
  syncStatus        SyncStatus @default(SYNCED)
  lastSyncedAt      DateTime?
  lastRemoteHash    String?
  lastLocalHash     String?
  syncError         String?
  sourceOfTruth     String   @default("ASAAS")
  version           Int      @default(1)
  // Local references
  localEntryId      String?
  localInvoiceId    String?
  remotePayload     Json?
  deletedAt         DateTime?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  organization  Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  customer      AsaasCustomer      @relation(fields: [customerId], references: [id])
  subscription  AsaasSubscription? @relation(fields: [subscriptionId], references: [id], onDelete: SetNull)
  statusHistory AsaasPaymentStatusHistory[]

  @@unique([organizationId, externalId])
  @@index([organizationId, status])
  @@index([organizationId, dueDate])
  @@index([organizationId, customerId])
  @@index([asaasCustomerId])
  @@index([subscriptionId])
  @@map("asaas_payments")
}

model AsaasPaymentStatusHistory {
  id        String   @id @default(cuid())
  paymentId String
  status    String
  source    String   @default("WEBHOOK") // WEBHOOK, API, MANUAL
  metadata  Json?
  createdAt DateTime @default(now())

  payment AsaasPayment @relation(fields: [paymentId], references: [id], onDelete: Cascade)

  @@index([paymentId, createdAt])
  @@map("asaas_payment_status_history")
}

// ============================================================
// ASAAS: ASSINATURAS
// ============================================================

model AsaasSubscription {
  id                String   @id @default(cuid())
  organizationId    String
  externalId        String   // Asaas subscription ID (sub_xxx)
  customerId        String   // FK to AsaasCustomer
  asaasCustomerId   String   // Asaas customer ID (cus_xxx)
  // Subscription data
  billingType       String
  value             Decimal  @db.Decimal(14, 2)
  cycle             String   // WEEKLY, BIWEEKLY, MONTHLY, etc.
  description       String?
  externalReference String?
  nextDueDate       DateTime?
  endDate           DateTime?
  maxPayments       Int?
  status            String   // ACTIVE, INACTIVE, EXPIRED
  // Sync fields
  syncStatus        SyncStatus @default(SYNCED)
  lastSyncedAt      DateTime?
  lastRemoteHash    String?
  lastLocalHash     String?
  syncError         String?
  sourceOfTruth     String   @default("ASAAS")
  version           Int      @default(1)
  // Local references
  localRecurrenceId String?
  localContractId   String?
  remotePayload     Json?
  deletedAt         DateTime?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  organization Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  customer     AsaasCustomer @relation(fields: [customerId], references: [id])
  payments     AsaasPayment[]

  @@unique([organizationId, externalId])
  @@index([organizationId, status])
  @@index([organizationId, customerId])
  @@map("asaas_subscriptions")
}

// ============================================================
// ASAAS: WEBHOOKS
// ============================================================

model AsaasWebhook {
  id             String   @id @default(cuid())
  organizationId String
  url            String
  email          String?
  apiVersion     String?  @default("3")
  enabled        Boolean  @default(true)
  interrupted    Boolean  @default(false)
  authToken      String?
  events         String[] // PAYMENT_CREATED, PAYMENT_RECEIVED, etc.
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization   Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  webhookEvents  AsaasWebhookEvent[]

  @@index([organizationId])
  @@map("asaas_webhooks")
}

model AsaasWebhookEvent {
  id             String   @id @default(cuid())
  webhookId      String?
  organizationId String?
  eventType      String   // PAYMENT_CREATED, PAYMENT_CONFIRMED, etc.
  eventId        String?  // Asaas event ID for idempotency
  rawPayload     Json
  status         WebhookEventStatus @default(PENDING)
  processedAt    DateTime?
  errorMessage   String?  @db.Text
  retryCount     Int      @default(0)
  maxRetries     Int      @default(5)
  nextRetryAt    DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  webhook AsaasWebhook? @relation(fields: [webhookId], references: [id], onDelete: SetNull)

  @@unique([eventId])
  @@index([status, nextRetryAt])
  @@index([eventType, createdAt])
  @@index([organizationId, createdAt])
  @@map("asaas_webhook_events")
}

enum WebhookEventStatus {
  PENDING
  PROCESSING
  PROCESSED
  FAILED
  DLQ
}

// ============================================================
// DOCUMENTOS FINANCEIROS
// ============================================================

model BillingDocument {
  id             String              @id @default(cuid())
  organizationId String
  type           BillingDocumentType
  number         String?
  title          String
  description    String?            @db.Text
  // Links
  customerId     String?
  paymentId      String?
  entryId        String?
  subscriptionId String?
  // Content
  templateId     String?
  variables      Json?
  htmlContent    String?            @db.Text
  pdfUrl         String?
  // Status
  status         DocumentStatus     @default(DRAFT)
  sentAt         DateTime?
  sentTo         String?
  // Versioning
  version        Int                @default(1)
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId, type, status])
  @@index([organizationId, customerId])
  @@map("billing_documents")
}

enum BillingDocumentType {
  INVOICE
  RECEIPT
  CONTRACT
  VOUCHER
  ACCEPTANCE_TERM
}

enum DocumentStatus {
  DRAFT
  GENERATED
  SENT
  VIEWED
  CANCELLED
}

// ============================================================
// NOTIFICAÇÕES FINANCEIRAS
// ============================================================

model FinancialNotification {
  id             String             @id @default(cuid())
  organizationId String
  type           NotificationType
  title          String
  message        String             @db.Text
  entityType     String?
  entityId       String?
