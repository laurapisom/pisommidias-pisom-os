generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================
// IDENTIDADE, CONTAS E PERMISSÕES
// ============================================================

model Organization {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  logo      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  members             OrganizationMember[]
  teams               Team[]
  leads               Lead[]
  contacts            Contact[]
  companies           Company[]
  deals               Deal[]
  pipelines           Pipeline[]
  tasks               Task[]
  auditLogs           AuditLog[]
  tags                Tag[]
  onboardings         Onboarding[]
  onboardingTemplates OnboardingTemplate[]
  contracts           Contract[]
  invoices            Invoice[]
  expenses            Expense[]
  costCenters         CostCenter[]
  expenseCategories   ExpenseCategory[]
  contentPosts        ContentPost[]
  contentIdeas        ContentIdea[]
  clientProfiles      ClientContentProfile[]
  integrations        Integration[]

  @@map("organizations")
}

model Integration {
  id             String    @id @default(cuid())
  organizationId String
  provider       String    // "asaas"
  apiKey         String
  sandbox        Boolean   @default(false)
  isActive       Boolean   @default(true)
  lastSyncAt     DateTime?
  syncStatus     String?
  syncError      String?
  syncProgress   Int?
  syncPhase      String?
  syncDetail     String?
  syncCancelled  Boolean   @default(false)
  settings       Json?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, provider])
  @@map("integrations")
}

model User {
  id           String    @id @default(cuid())
  email        String    @unique
  passwordHash String
  firstName    String
  lastName     String
  avatar       String?
  phone        String?
  isActive     Boolean   @default(true)
  lastLoginAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  memberships     OrganizationMember[]
  teamMembers     TeamMember[]
  assignedTasks   Task[]            @relation("TaskAssignee")
  createdTasks    Task[]            @relation("TaskCreator")
  createdDeals    Deal[]            @relation("DealCreator")
  ownedDeals      Deal[]            @relation("DealOwner")
  activities      Activity[]
  auditLogs       AuditLog[]
  comments        Comment[]
  onboardingsResponsible Onboarding[] @relation("OnboardingResponsible")
  onboardingItemsCompleted OnboardingItem[] @relation("OnboardingItemCompletedBy")
  expensesCreated  Expense[] @relation("ExpenseCreator")
  expensesApproved Expense[] @relation("ExpenseApprover")
  contentPostsCreated  ContentPost[] @relation("ContentPostCreator")
  contentPostsAssigned ContentPost[] @relation("ContentPostAssignee")
  contentIdeasCreated  ContentIdea[] @relation("ContentIdeaCreator")
  contentVersions      ContentVersion[]

  @@map("users")
}

model OrganizationMember {
  id             String   @id @default(cuid())
  organizationId String
  userId         String
  role           OrgRole  @default(MEMBER)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([organizationId, userId])
  @@map("organization_members")
}

enum OrgRole {
  OWNER
  ADMIN
  MANAGER
  MEMBER
  VIEWER
}

model Team {
  id             String   @id @default(cuid())
  organizationId String
  name           String
  description    String?
  color          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  members      TeamMember[]

  @@map("teams")
}

model TeamMember {
  id        String   @id @default(cuid())
  teamId    String
  userId    String
  role      String   @default("member")
  createdAt DateTime @default(now())

  team Team @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([teamId, userId])
  @@map("team_members")
}

model AuditLog {
  id             String   @id @default(cuid())
  organizationId String
  userId         String?
  action         String
  entity         String
  entityId       String?
  oldData        Json?
  newData        Json?
  ipAddress      String?
  userAgent      String?
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User?        @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([organizationId, entity, entityId])
  @@index([organizationId, createdAt])
  @@map("audit_logs")
}

// ============================================================
// CRM + PIPELINE DE VENDAS
// ============================================================

model Contact {
  id             String   @id @default(cuid())
  organizationId String
  firstName      String
  lastName       String?
  email          String?
  phone          String?
  whatsapp       String?
  position       String?
  companyId      String?
  avatar         String?
  customFields   Json?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  company      Company?     @relation(fields: [companyId], references: [id], onDelete: SetNull)
  leads        Lead[]
  deals        DealContact[]
  activities   Activity[]

  @@index([organizationId, email])
  @@map("contacts")
}

model Company {
  id             String   @id @default(cuid())
  organizationId String
  name           String
  domain         String?
  cnpj           String?
  phone          String?
  address        String?
  city           String?
  state          String?
  industry       String?
  size           String?
  logo           String?
  customFields    Json?
  asaasCustomerId String?
  isCustomer      Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  contacts     Contact[]
  leads        Lead[]
  deals        Deal[]
  contracts    Contract[]
  invoices     Invoice[]   @relation("InvoiceCompany")

  @@index([organizationId])
  @@index([organizationId, asaasCustomerId])
  @@map("companies")
}

model Lead {
  id             String     @id @default(cuid())
  organizationId String
  contactId      String?
  companyId      String?
  source         String?
  status         LeadStatus @default(NEW)
  score          Int        @default(0)
  customFields   Json?
  convertedAt    DateTime?
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  contact      Contact?     @relation(fields: [contactId], references: [id], onDelete: SetNull)
  company      Company?     @relation(fields: [companyId], references: [id], onDelete: SetNull)
  deals        Deal[]
  activities   Activity[]
  tags         TagAssignment[]

  @@index([organizationId, status])
  @@index([organizationId, createdAt])
  @@map("leads")
}

enum LeadStatus {
  NEW
  CONTACTED
  QUALIFIED
  UNQUALIFIED
  CONVERTED
  LOST
}

model Pipeline {
  id             String   @id @default(cuid())
  organizationId String
  name           String
  description    String?
  isDefault      Boolean  @default(false)
  position       Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  stages       PipelineStage[]
  deals        Deal[]

  @@map("pipelines")
}

model PipelineStage {
  id         String   @id @default(cuid())
  pipelineId String
  name       String
  color      String?
  position   Int      @default(0)
  probability Int     @default(0)  // 0-100%
  slaHours   Int?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  pipeline Pipeline @relation(fields: [pipelineId], references: [id], onDelete: Cascade)
  deals    Deal[]

  @@map("pipeline_stages")
}

model Deal {
  id             String     @id @default(cuid())
  organizationId String
  pipelineId     String
  stageId        String
  leadId         String?
  companyId      String?
  ownerId        String
  createdById    String
  title          String
  value          Decimal?   @db.Decimal(12, 2)
  currency       String     @default("BRL")
  status         DealStatus @default(OPEN)
  expectedCloseDate DateTime?
  closedAt       DateTime?
  lostReason     String?
  wonReason      String?
  position       Int        @default(0)
  customFields   Json?
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  organization Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  pipeline     Pipeline      @relation(fields: [pipelineId], references: [id])
  stage        PipelineStage @relation(fields: [stageId], references: [id])
  lead         Lead?         @relation(fields: [leadId], references: [id], onDelete: SetNull)
  company      Company?      @relation(fields: [companyId], references: [id], onDelete: SetNull)
  owner        User          @relation("DealOwner", fields: [ownerId], references: [id])
  createdBy    User          @relation("DealCreator", fields: [createdById], references: [id])
  contacts     DealContact[]
  activities   Activity[]
  tasks        Task[]
  tags         TagAssignment[]
  comments     Comment[]

  @@index([organizationId, pipelineId, stageId])
  @@index([organizationId, status])
  @@map("deals")
}

model DealContact {
  id        String @id @default(cuid())
  dealId    String
  contactId String
  role      String @default("primary")

  deal    Deal    @relation(fields: [dealId], references: [id], onDelete: Cascade)
  contact Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@unique([dealId, contactId])
  @@map("deal_contacts")
}

enum DealStatus {
  OPEN
  WON
  LOST
  ARCHIVED
}

// ============================================================
// ATIVIDADES E TIMELINE
// ============================================================

model Activity {
  id             String       @id @default(cuid())
  organizationId String
  userId         String
  type           ActivityType
  title          String
  description    String?
  metadata       Json?
  leadId         String?
  dealId         String?
  contactId      String?
  scheduledAt    DateTime?
  completedAt    DateTime?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  user    User     @relation(fields: [userId], references: [id])
  lead    Lead?    @relation(fields: [leadId], references: [id], onDelete: SetNull)
  deal    Deal?    @relation(fields: [dealId], references: [id], onDelete: SetNull)
  contact Contact? @relation(fields: [contactId], references: [id], onDelete: SetNull)

  @@index([dealId, createdAt])
  @@index([leadId, createdAt])
  @@index([contactId, createdAt])
  @@map("activities")
}

enum ActivityType {
  NOTE
  CALL
  EMAIL
  MEETING
  TASK
  WHATSAPP
  PROPOSAL
  CONTRACT
  STAGE_CHANGE
  STATUS_CHANGE
  SYSTEM
}

// ============================================================
// TAREFAS E FOLLOW-UPS
// ============================================================

model Task {
  id             String     @id @default(cuid())
  organizationId String
  assigneeId     String?
  createdById    String
  dealId         String?
  title          String
  description    String?
  priority       Priority   @default(MEDIUM)
  status         TaskStatus @default(TODO)
  dueDate        DateTime?
  completedAt    DateTime?
  slaDeadline    DateTime?
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  assignee     User?        @relation("TaskAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)
  createdBy    User         @relation("TaskCreator", fields: [createdById], references: [id])
  deal         Deal?        @relation(fields: [dealId], references: [id], onDelete: SetNull)
  comments     Comment[]
  tags         TagAssignment[]

  @@index([organizationId, status])
  @@index([assigneeId, status])
  @@index([dueDate])
  @@map("tasks")
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  WAITING
  DONE
  CANCELLED
}

// ============================================================
// TAGS E COMENTÁRIOS
// ============================================================

model Tag {
  id             String   @id @default(cuid())
  organizationId String
  name           String
  color          String?
  createdAt      DateTime @default(now())

  organization Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  assignments  TagAssignment[]

  @@unique([organizationId, name])
  @@map("tags")
}

model TagAssignment {
  id         String @id @default(cuid())
  tagId      String
  entityType String
  entityId   String

  tag Tag @relation(fields: [tagId], references: [id], onDelete: Cascade)

  leadId String?
  lead   Lead?   @relation(fields: [leadId], references: [id], onDelete: Cascade)
  dealId String?
  deal   Deal?   @relation(fields: [dealId], references: [id], onDelete: Cascade)
  taskId String?
  task   Task?   @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@unique([tagId, entityType, entityId])
  @@index([entityType, entityId])
  @@map("tag_assignments")
}

model Comment {
  id        String   @id @default(cuid())
  userId    String
  content   String
  entityType String
  entityId  String
  dealId    String?
  taskId    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User  @relation(fields: [userId], references: [id])
  deal Deal? @relation(fields: [dealId], references: [id], onDelete: Cascade)
  task Task? @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([entityType, entityId])
  @@map("comments")
}

// ============================================================
// ONBOARDING E DIAGNÓSTICO
// ============================================================

model OnboardingTemplate {
  id             String   @id @default(cuid())
  organizationId String
  name           String
  description    String?
  serviceType    ServiceType
  isActive       Boolean  @default(true)
  position       Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization              @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  sections     OnboardingTemplateSection[]
  onboardings  Onboarding[]

  @@index([organizationId, serviceType])
  @@map("onboarding_templates")
}

model OnboardingTemplateSection {
  id         String   @id @default(cuid())
  templateId String
  name       String
  description String?
  position   Int      @default(0)
  createdAt  DateTime @default(now())

  template OnboardingTemplate            @relation(fields: [templateId], references: [id], onDelete: Cascade)
  items    OnboardingTemplateItem[]

  @@map("onboarding_template_sections")
}

model OnboardingTemplateItem {
  id          String                @id @default(cuid())
  sectionId   String
  title       String
  description String?
  itemType    OnboardingItemType    @default(CHECKBOX)
  isRequired  Boolean               @default(true)
  position    Int                   @default(0)
  metadata    Json?
  createdAt   DateTime              @default(now())

  section OnboardingTemplateSection @relation(fields: [sectionId], references: [id], onDelete: Cascade)

  @@map("onboarding_template_items")
}

enum ServiceType {
  TRAFEGO_PAGO
  SOCIAL_MEDIA
  WEBSITE
  CRM_AUTOMACAO
  BRANDING
  SEO
  EMAIL_MARKETING
  CONSULTORIA
  CUSTOM
}

enum OnboardingItemType {
  CHECKBOX
  TEXT_INPUT
  FILE_UPLOAD
  URL_INPUT
  CREDENTIAL
  SELECT
  DATE
  SIGNATURE
}

model Onboarding {
  id             String           @id @default(cuid())
  organizationId String
  templateId     String?
  dealId         String?
  companyId      String?
  responsibleId  String?
  title          String
  serviceType    ServiceType
  status         OnboardingStatus @default(PENDING)
  notes          String?
  startedAt      DateTime?
  completedAt    DateTime?
  dueDate        DateTime?
  acceptedTermsAt DateTime?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  organization Organization         @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  template     OnboardingTemplate?  @relation(fields: [templateId], references: [id], onDelete: SetNull)
  responsible  User?                @relation("OnboardingResponsible", fields: [responsibleId], references: [id], onDelete: SetNull)
  sections     OnboardingSection[]

  @@index([organizationId, status])
  @@index([organizationId, dealId])
  @@map("onboardings")
}

enum OnboardingStatus {
  PENDING
  IN_PROGRESS
  WAITING_CLIENT
  REVIEW
  COMPLETED
  CANCELLED
}

model OnboardingSection {
  id            String   @id @default(cuid())
  onboardingId  String
  name          String
  description   String?
  position      Int      @default(0)
  createdAt     DateTime @default(now())

  onboarding Onboarding       @relation(fields: [onboardingId], references: [id], onDelete: Cascade)
  items      OnboardingItem[]

  @@map("onboarding_sections")
}

model OnboardingItem {
  id            String              @id @default(cuid())
  sectionId     String
  title         String
  description   String?
  itemType      OnboardingItemType  @default(CHECKBOX)
  isRequired    Boolean             @default(true)
  position      Int                 @default(0)
  isCompleted   Boolean             @default(false)
  completedAt   DateTime?
  completedById String?
  value         String?
  fileUrl       String?
  notes         String?
  metadata      Json?
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt

  section     OnboardingSection @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  completedBy User?             @relation("OnboardingItemCompletedBy", fields: [completedById], references: [id], onDelete: SetNull)

  @@map("onboarding_items")
}

// ============================================================
// FINANCEIRO: CONTRATOS E RECORRÊNCIA
// ============================================================

model Contract {
  id             String         @id @default(cuid())
  organizationId String
  companyId      String?
  dealId         String?
  title          String
  description    String?
  status         ContractStatus @default(ACTIVE)
  billingCycle   BillingCycle   @default(MONTHLY)
  value          Decimal        @db.Decimal(12, 2)
  currency       String         @default("BRL")
  startDate      DateTime
  endDate        DateTime?
  nextBillingDate DateTime?
  dayOfMonth     Int            @default(10)
  autoRenew      Boolean        @default(true)
  services       String[]
  asaasCustomerId  String?
  asaasSubscriptionId String?
  notes          String?
  cancelledAt    DateTime?
  cancelReason   String?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  company      Company?     @relation(fields: [companyId], references: [id])
  invoices     Invoice[]

  @@index([organizationId, status])
  @@index([organizationId, companyId])
  @@index([nextBillingDate])
  @@map("contracts")
}

enum ContractStatus {
  DRAFT
  ACTIVE
  PAUSED
  CANCELLED
  EXPIRED
}

enum BillingCycle {
  MONTHLY
  QUARTERLY
  SEMIANNUAL
  ANNUAL
  CUSTOM
}

model Invoice {
  id             String        @id @default(cuid())
  organizationId String
  contractId     String?
  companyId      String?
  number         String?
  status         InvoiceStatus @default(PENDING)
  type           InvoiceType   @default(RECURRING)
  value          Decimal       @db.Decimal(12, 2)
  discount       Decimal?      @db.Decimal(12, 2)
  tax            Decimal?      @db.Decimal(12, 2)
  totalValue     Decimal       @db.Decimal(12, 2)
  currency       String        @default("BRL")
  description    String?
  dueDate        DateTime
  paidAt         DateTime?
  paidValue      Decimal?      @db.Decimal(12, 2)
  paymentMethod  String?
  referenceMonth String?
  asaasPaymentId String?
  asaasBillingType String?
  asaasInvoiceUrl  String?
  asaasBankSlipUrl String?
  asaasPixCode     String?
  notes          String?
  reminders      Json?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  contract     Contract?    @relation(fields: [contractId], references: [id], onDelete: SetNull)
  company      Company?     @relation("InvoiceCompany", fields: [companyId], references: [id], onDelete: SetNull)

  @@index([organizationId, status])
  @@index([organizationId, dueDate])
  @@index([organizationId, contractId])
  @@index([asaasPaymentId])
  @@map("invoices")
}

enum InvoiceStatus {
  DRAFT
  PENDING
  SENT
  OVERDUE
  PAID
  PARTIALLY_PAID
  CANCELLED
  REFUNDED
}

enum InvoiceType {
  RECURRING
  ONE_TIME
  ADDITIONAL
  CREDIT
}

// ============================================================
// FINANCEIRO: DESPESAS, CENTROS DE CUSTO E FLUXO DE CAIXA
// ============================================================

model ExpenseCategory {
  id             String   @id @default(cuid())
  organizationId String
  name           String
  color          String?
  parentId       String?
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())

  organization Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  parent       ExpenseCategory?  @relation("ExpenseCategoryTree", fields: [parentId], references: [id], onDelete: SetNull)
  children     ExpenseCategory[] @relation("ExpenseCategoryTree")
  expenses     Expense[]

  @@unique([organizationId, name])
  @@map("expense_categories")
}

model CostCenter {
  id             String   @id @default(cuid())
  organizationId String
  name           String
  type           CostCenterType @default(GENERAL)
  referenceId    String?
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  expenses     Expense[]

  @@unique([organizationId, name])
  @@map("cost_centers")
}

enum CostCenterType {
  CLIENT
  PROJECT
  SQUAD
  DEPARTMENT
  GENERAL
}

model Expense {
  id             String        @id @default(cuid())
  organizationId String
  categoryId     String?
  costCenterId   String?
  createdById    String
  approvedById   String?
  title          String
  description    String?
  value          Decimal       @db.Decimal(12, 2)
  currency       String        @default("BRL")
  status         ExpenseStatus @default(PENDING)
  type           ExpenseType   @default(FIXED)
  dueDate        DateTime
  paidAt         DateTime?
  recurrence     BillingCycle?
  supplier       String?
  invoiceNumber  String?
  attachmentUrl       String?
  notes               String?
  asaasTransactionId  String?   @unique
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  organization Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  category     ExpenseCategory?  @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  costCenter   CostCenter?       @relation(fields: [costCenterId], references: [id], onDelete: SetNull)
  createdBy    User              @relation("ExpenseCreator", fields: [createdById], references: [id])
  approvedBy   User?             @relation("ExpenseApprover", fields: [approvedById], references: [id], onDelete: SetNull)

  @@index([organizationId, status])
  @@index([organizationId, dueDate])
  @@index([organizationId, categoryId])
  @@index([organizationId, costCenterId])
  @@map("expenses")
}

enum ExpenseStatus {
  PENDING
  APPROVED
  PAID
  REJECTED
  CANCELLED
}

enum ExpenseType {
  FIXED
  VARIABLE
  ONE_TIME
  INVESTMENT
}

// ─── Content + Editorial Calendar ─────────────────────────────────────

model ClientContentProfile {
  id             String   @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  clientName     String
  brandVoice     String?  @db.Text
  visualGuide    String?  @db.Text
  targetAudience String?  @db.Text
  competitors    String?  @db.Text
  hashtags       String?  @db.Text
  channels       ContentChannel[]
  notes          String?  @db.Text
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  posts          ContentPost[]
  ideas          ContentIdea[]

  @@index([organizationId])
}

model ContentPost {
  id               String        @id @default(cuid())
  organizationId   String
  organization     Organization  @relation(fields: [organizationId], references: [id])
  profileId        String?
  profile          ClientContentProfile? @relation(fields: [profileId], references: [id])
  title            String
  content          String?       @db.Text
  caption          String?       @db.Text
  channel          ContentChannel
  status           ContentStatus @default(IDEA)
  scheduledAt      DateTime?
  publishedAt      DateTime?
  createdById      String
  createdBy        User          @relation("ContentPostCreator", fields: [createdById], references: [id])
  assignedToId     String?
  assignedTo       User?         @relation("ContentPostAssignee", fields: [assignedToId], references: [id])
  tags             String[]
  mediaUrls        String[]
  rejectionReason  String?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  versions         ContentVersion[]

  @@index([organizationId])
  @@index([profileId])
  @@index([status])
  @@index([scheduledAt])
  @@index([channel])
}

model ContentIdea {
  id             String   @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  profileId      String?
  profile        ClientContentProfile? @relation(fields: [profileId], references: [id])
  title          String
  description    String?  @db.Text
  channel        ContentChannel?
  reference      String?  @db.Text
  status         IdeaStatus @default(NEW)
  createdById    String
  createdBy      User     @relation("ContentIdeaCreator", fields: [createdById], references: [id])
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([organizationId])
  @@index([profileId])
}

model ContentVersion {
  id        String   @id @default(cuid())
  postId    String
  post      ContentPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  version   Int
  content   String?  @db.Text
  caption   String?  @db.Text
  note      String?  @db.Text
  createdById String
  createdBy User     @relation(fields: [createdById], references: [id])
  createdAt DateTime @default(now())

  @@unique([postId, version])
  @@index([postId])
}

enum ContentChannel {
  INSTAGRAM_FEED
  INSTAGRAM_STORIES
  INSTAGRAM_REELS
  FACEBOOK
  TIKTOK
  YOUTUBE
  LINKEDIN
  TWITTER
  BLOG
  EMAIL
  WHATSAPP
  OTHER
}

enum ContentStatus {
  IDEA
  DRAFT
  IN_REVIEW
  APPROVED
  SCHEDULED
  PUBLISHED
  REJECTED
}

enum IdeaStatus {
  NEW
  APPROVED
  REJECTED
  USED
}
