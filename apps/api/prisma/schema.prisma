  @@index([organizationId, recipientId, status])
  @@index([organizationId, type, createdAt])
  @@map("financial_notifications")
}

enum NotificationType {
  DUE_DATE_REMINDER
  OVERDUE_ALERT
  PAYMENT_RECEIVED
  PAYMENT_FAILED
  SYNC_ERROR
  SYNC_DIVERGENCE
  SUBSCRIPTION_RENEWAL
  CARD_DECLINED
  RECONCILIATION_PENDING
  PERIOD_CLOSING
  CASH_FLOW_RISK
}

enum NotificationChannel {
  INTERNAL
  EMAIL
  WHATSAPP
  SMS
}

enum NotificationStatus {
  PENDING
  SENT
  READ
  FAILED
}

// ============================================================
// SYNC LOGS
// ============================================================

model SyncLog {
  id             String   @id @default(cuid())
  organizationId String
  entity         String
  entityId       String?
  action         String
  direction      String   // PUSH, PULL, RECONCILE
  status         String   // SUCCESS, ERROR, SKIPPED
  details        String?  @db.Text
  metadata       Json?
  duration       Int?     // ms
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId, entity, createdAt])
  @@index([organizationId, status, createdAt])
  @@map("sync_logs")
}

// ============================================================
// CONFIGURAÇÕES DO SISTEMA
// ============================================================

model SystemSetting {
  id             String   @id @default(cuid())
  organizationId String
  key            String
  value          Json
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, key])
  @@map("system_settings")
}

// ============================================================
// Content + Editorial Calendar
// ============================================================

model ClientContentProfile {
  id             String   @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  clientName     String
  brandVoice     String?  @db.Text
  visualGuide    String?  @db.Text
  targetAudience String?  @db.Text
  competitors    String?  @db.Text
  hashtags       String?  @db.Text
  channels       ContentChannel[]
  notes          String?  @db.Text
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  posts          ContentPost[]
  ideas          ContentIdea[]

  @@index([organizationId])
}

model ContentPost {
  id               String        @id @default(cuid())
  organizationId   String
  organization     Organization  @relation(fields: [organizationId], references: [id])
  profileId        String?
  profile          ClientContentProfile? @relation(fields: [profileId], references: [id])
  title            String
  content          String?       @db.Text
  caption          String?       @db.Text
  channel          ContentChannel
  status           ContentStatus @default(IDEA)
  scheduledAt      DateTime?
  publishedAt      DateTime?
  createdById      String
  createdBy        User          @relation("ContentPostCreator", fields: [createdById], references: [id])
  assignedToId     String?
  assignedTo       User?         @relation("ContentPostAssignee", fields: [assignedToId], references: [id])
  tags             String[]
  mediaUrls        String[]
  rejectionReason  String?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  versions         ContentVersion[]

  @@index([organizationId])
  @@index([profileId])
  @@index([status])
  @@index([scheduledAt])
  @@index([channel])
}

model ContentIdea {
  id             String   @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  profileId      String?
  profile        ClientContentProfile? @relation(fields: [profileId], references: [id])
  title          String
  description    String?  @db.Text
  channel        ContentChannel?
  reference      String?  @db.Text
  status         IdeaStatus @default(NEW)
  createdById    String
  createdBy      User     @relation("ContentIdeaCreator", fields: [createdById], references: [id])
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([organizationId])
  @@index([profileId])
}

model ContentVersion {
  id        String   @id @default(cuid())
  postId    String
  post      ContentPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  version   Int
  content   String?  @db.Text
  caption   String?  @db.Text
  note      String?  @db.Text
  createdById String
  createdBy User     @relation(fields: [createdById], references: [id])
  createdAt DateTime @default(now())

  @@unique([postId, version])
  @@index([postId])
}

enum ContentChannel {
  INSTAGRAM_FEED
  INSTAGRAM_STORIES
  INSTAGRAM_REELS
  FACEBOOK
  TIKTOK
  YOUTUBE
  LINKEDIN
  TWITTER
  BLOG
  EMAIL
  WHATSAPP
  OTHER
}

enum ContentStatus {
  IDEA
  DRAFT
  IN_REVIEW
  APPROVED
  SCHEDULED
  PUBLISHED
  REJECTED
}

enum IdeaStatus {
  NEW
  APPROVED
  REJECTED
  USED
}
